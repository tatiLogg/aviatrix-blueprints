{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AviatrixPowerUserAccess",
      "Effect": "Allow",
      "NotAction": ["iam:*", "organizations:*", "account:*"],
      "Resource": "*"
    },
    {
      "Sid": "AviatrixIAMReadAccess",
      "Effect": "Allow",
      "Action": ["iam:Get*", "iam:List*", "iam:GenerateServiceLastAccessedDetails", "iam:SimulatePrincipalPolicy", "iam:SimulateCustomPolicy"],
      "Resource": "*"
    },
    {
      "Sid": "AviatrixIAMWriteAccess",
      "Effect": "Allow",
      "Action": ["iam:CreateInstanceProfile", "iam:DeleteInstanceProfile", "iam:TagInstanceProfile", "iam:UntagInstanceProfile", "iam:AddRoleToInstanceProfile", "iam:RemoveRoleFromInstanceProfile", "iam:PassRole", "iam:CreateRole", "iam:DeleteRole", "iam:AttachRolePolicy", "iam:DetachRolePolicy", "iam:PutRolePolicy", "iam:DeleteRolePolicy", "iam:CreatePolicy", "iam:DeletePolicy", "iam:CreatePolicyVersion", "iam:DeletePolicyVersion", "iam:TagRole", "iam:UntagRole", "iam:TagPolicy", "iam:UntagPolicy"],
      "Resource": "*"
    }
  ]
}
